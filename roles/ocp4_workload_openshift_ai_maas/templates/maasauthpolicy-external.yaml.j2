apiVersion: maas.opendatahub.io/v1alpha1
kind: MaaSAuthPolicy
metadata:
  name: "{{ item.name }}-access"
  namespace: models-as-a-service
  annotations:
    openshift.io/display-name: "{{ item.name }} Access"
spec:
  modelRefs:
    - name: "{{ item.name }}"
      namespace: external-models
  subjects:
    groups:
      - name: system:authenticated
    users: []
