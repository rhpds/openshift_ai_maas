apiVersion: maas.opendatahub.io/v1alpha1
kind: MaaSSubscription
metadata:
  name: simulator-default
  namespace: models-as-a-service
  annotations:
    openshift.io/display-name: Simulator Default Tier
    openshift.io/description: "Default tier: 100000 tokens/min for all authenticated users"
spec:
  owner:
    groups:
      - name: system:authenticated
    users: []
  modelRefs:
    - name: simulated
      namespace: llm
      tokenRateLimits:
        - limit: 100000
          window: 1m
  priority: 10
